{
    "executionRoleArn": "AWS_EXECUTION_ROLE_PLACEHOLDER",
    "containerDefinitions": [
        {
            "name": "atoti-session",
            "environment": [
                {
                    "name": "DATA_REFRESH_PERIOD",
                    "value": "60"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/atoti-project-template",
                    "awslogs-region": "AWS_REGION_PLACEHOLDER",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "portMappings": [
                {
                    "hostPort": 80,
                    "protocol": "tcp",
                    "containerPort": 80
                }
            ],
            "healthCheck": {
                "command": [
                    "CMD",
                    "python",
                    "-c",
                    "import httpx; httpx.get('http://localhost/actuator/health/readiness').raise_for_status()"
                ],
                "startPeriod": 30
            },
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "arn:aws:secretsmanager:AWS_REGION_PLACEHOLDER:AWS_ACCOUNT_ID_PLACEHOLDER:secret:atoti-project-template/AWS_DATABASE_URL_SECRET_NAME_PLACEHOLDER"
                }
            ]
        }
    ],
    "family": "atoti-project-template",
    "cpu": "1024",
    "memory": "2048",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "networkMode": "awsvpc"
}
